# Portal Raportów Pracowniczych - Environment Configuration
# Generated automatically by setup process

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_PORT=3000

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=portal_reports
DB_USER=portal_user
DB_PASSWORD=secure_db_password_123456789

# JWT Configuration - Change in production!
JWT_SECRET=jwt_secret_your_super_secret_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# SMTP Email Configuration - Configure with your email provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=reports@company.com
EMAIL_RECIPIENTS=manager@company.com,admin@company.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,xls,xlsx
UPLOAD_PATH=./uploads

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_REGISTRATION=false
ENABLE_EMAIL_NOTIFICATIONS=true
TEXT_FIELD_MAX_LENGTH=300

# Nginx Configuration (for production profile)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Company Information
COMPANY_NAME=Firma Budowlana
COMPANY_ADDRESS=ul. Budowlana 123, 00-001 Warszawa
COMPANY_PHONE=+48 22 123 45 67